---

import { profileConfig, siteConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
// Helper: compute uptime from startDate string (ISO) to now, return Chinese human-readable like "2年3月" or "5个月12天"
function formatUptime(startDateStr: string | undefined) {
    if (!startDateStr) return null;
    const start = new Date(startDateStr);
    if (isNaN(start.getTime())) return null;
    const now = new Date();

    let years = now.getFullYear() - start.getFullYear();
    let months = now.getMonth() - start.getMonth();
    let days = now.getDate() - start.getDate();

    if (days < 0) {
        const prevMonth = new Date(now.getFullYear(), now.getMonth(), 0);
        days += prevMonth.getDate();
        months -= 1;
    }
    if (months < 0) {
        months += 12;
        years -= 1;
    }

    const parts: string[] = [];
    if (years > 0) {
        parts.push(`${years}年`);
        // when years>0, show months and days if present
        if (months > 0) {
            parts.push(`${months}月${days > 0 ? `${days}天` : ""}`);
        } else if (days > 0) {
            parts.push(`${days}天`);
        }
    } else if (months > 0) {
        // no years, show months and days together (e.g., "1月12天")
        parts.push(`${months}月${days > 0 ? `${days}天` : ""}`);
    } else if (days > 0) {
        parts.push(`${days}天`);
    }

    if (parts.length === 0) return `0天`;
    return parts.join("");
}
---

